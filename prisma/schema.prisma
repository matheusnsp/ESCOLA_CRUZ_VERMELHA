generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id                   String         @id @default(uuid())
  nome                 String
  email                String         @unique
  tipoDocumento        TipoDocumento?
  cpfCnpj              String?        @unique
  passaporte           String?        @unique
  paisOrigem           String?
  senhaHash            String?
  papel                Papel          @default(ALUNO)
  escolaridade         String?
  escolaridadeSituacao String?
  genero               String?
  cep                  String?
  logradouro           String?
  numero               String?
  complemento          String?
  bairro               String?
  cidade               String?
  uf                   String?
  emailVerificado      Boolean        @default(false)
  loginFalhas          Int            @default(0)
  bloqueadoAte         DateTime?
  loginStrikes         Int            @default(0)
  bloqueioTotal        Boolean        @default(false)
  avatarUrl            String?
  consentimentoLgpdEm  DateTime?
  consentimentoVersao  String?
  criadoEm             DateTime       @default(now())
  atualizadoEm         DateTime       @updatedAt
  celular              String?
  rg                   String?
  matriculas           Matricula[]

  @@index([papel])
}

model Curso {
  id                 String     @id @default(uuid())
  nome               String
  descricao          String?
  cargaHoraria       Int
  escolaridadeMinima String?
  imagemUrl          String?
  precoAvista        Decimal    @db.Decimal(10, 2)
  precoCheio         Decimal    @db.Decimal(10, 2)
  parcelas           Int        @default(1)
  valorParcela       Decimal    @db.Decimal(10, 2)
  taxaMatricula      Decimal?   @db.Decimal(10, 2)
  ativo              Boolean    @default(true)
  criadoEm          DateTime   @default(now())
  descricaoLonga     String?
  faqs               FaqCurso[]
  turmas             Turma[]
}

model FaqCurso {
  id       String   @id @default(uuid())
  cursoId  String
  pergunta String
  resposta String
  ordem    Int      @default(0)
  criadoEm DateTime @default(now())
  curso    Curso    @relation(fields: [cursoId], references: [id], onDelete: Cascade)

  @@index([cursoId])
}

model Turma {
  id             String      @id @default(uuid())
  cursoId        String
  inicioPrevisto DateTime @default(now())
  vagas          Int         @default(30)
  minimoAlunos   Int         @default(15)
  status         StatusTurma @default(ABERTA)
  criadoEm       DateTime    @default(now())
  aulas          AulaData[]
  matriculas     Matricula[]
  curso          Curso       @relation(fields: [cursoId], references: [id])
}

model AulaData {
  id      String   @id @default(uuid())
  turmaId String
  data    DateTime @db.Date
  horario String
  turma   Turma    @relation(fields: [turmaId], references: [id], onDelete: Cascade)

  @@index([turmaId])
  @@index([data])
}

model Matricula {
  id                  String             @id @default(uuid())
  alunoId             String
  turmaId             String
  plano               PlanoPagamento
  forma               FormaPagamento
  valorCurso          Decimal            @db.Decimal(10, 2)
  valorTaxaMatricula  Decimal            @default(0) @db.Decimal(10, 2)
  alimentoEntregue    Boolean            @default(false)
  alimentoEntreguePor String?
  alimentoEntregueEm  DateTime?
  taxaConfirmada      Boolean            @default(false)
  taxaConfirmadaPor   String?
  taxaConfirmadaEm    DateTime?
  statusPagamento     StatusPagamento    @default(PENDENTE)
  nota                Float?
  situacao            SituacaoAcademica?
  confirmadaPor       String?
  confirmadaEm        DateTime?
  criadoEm            DateTime           @default(now())
  atualizadoEm        DateTime           @updatedAt
  avaliacoes          Avaliacao[]
  aluno               Usuario            @relation(fields: [alunoId], references: [id])
  turma               Turma              @relation(fields: [turmaId], references: [id])
  pagamentos          Pagamento[]

  @@unique([alunoId, turmaId])
}

model Pagamento {
  id              String          @id @default(uuid())
  matriculaId     String
  gateway         String?
  gatewayRef      String?
  gatewayHash     String?
  gatewayStatus   String?
  gatewayResponse Json?
  pixQrCode       String?         @db.Text
  pixUrl          String?         @db.Text
  pixBase64       String?         @db.Text
  metodo          FormaPagamento
  valor           Decimal         @db.Decimal(10, 2)
  status          StatusPagamento @default(PENDENTE)
  criadoEm        DateTime        @default(now())
  atualizadoEm    DateTime        @updatedAt
  matricula       Matricula       @relation(fields: [matriculaId], references: [id])

  @@index([matriculaId])
  @@index([gatewayRef])
  @@index([gatewayHash])
  @@index([status])
}

model TokenAuth {
  id        String    @id @default(uuid())
  usuarioId String
  tipo      String
  tokenHash String
  expiraEm  DateTime
  usadoEm   DateTime?
  criadoEm  DateTime  @default(now())

  @@index([usuarioId, tipo])
}

model Configuracao {
  chave String @id
  valor String
}

model LogAuditoria {
  id       String   @id @default(uuid())
  atorId   String
  acao     String
  alvoTipo String
  alvoId   String?
  detalhe  Json?
  criadoEm DateTime @default(now())

  @@index([atorId])
  @@index([acao])
  @@index([criadoEm])
}

model Avaliacao {
  id          String    @id @default(uuid())
  matriculaId String
  nome        String
  nota        Float
  peso        Float     @default(1)
  criadoEm    DateTime  @default(now())
  matricula   Matricula @relation(fields: [matriculaId], references: [id], onDelete: Cascade)

  @@index([matriculaId])
}

model session {
  sid    String   @id @db.VarChar
  sess   Json     @db.Json
  expire DateTime @db.Timestamp(6)

  @@index([expire], map: "IDX_session_expire")
}

enum Papel {
  ALUNO
  SECRETARIA
  COORDENADOR
  FINANCEIRO
  DEV
}

enum TipoDocumento {
  CPF
  CNPJ
  PASSAPORTE
}

enum StatusTurma {
  ABERTA
  CONFIRMADA
  CANCELADA
  ENCERRADA
}

enum PlanoPagamento {
  A_VISTA
  PARCELADO
}

enum FormaPagamento {
  PIX
  DEBITO
  CREDITO
  DINHEIRO
}

enum StatusPagamento {
  PENDENTE
  PAGO
  CANCELADO
  ESTORNADO
  PARCELADO
}

enum SituacaoAcademica {
  APROVADO
  REPROVADO
}