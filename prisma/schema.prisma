// ============================================================
//  Esquema do banco — Escola de Capacitação (Cruz Vermelha RJ)
//  Banco: PostgreSQL  |  ORM: Prisma
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------

enum Papel {
  ALUNO
  SECRETARIA
}

enum StatusTurma {
  ABERTA
  CONFIRMADA
  CANCELADA
  ENCERRADA
}

enum PlanoPagamento {
  A_VISTA // pagamento único, com desconto
  PARCELADO // preço cheio dividido em parcelas
}

enum FormaPagamento {
  PIX
  DEBITO
  CREDITO
  DINHEIRO // presencial, confirmado manualmente pela secretaria
}

enum StatusPagamento {
  PENDENTE
  PAGO
  CANCELADO
  ESTORNADO
  PARCELADO
}

enum SituacaoAcademica {
  APROVADO
  REPROVADO
}

// ---------- Usuário ----------
// O cadastro público SEMPRE cria papel = ALUNO.
// Conta SECRETARIA é criada via seed/painel admin, nunca pelo formulário público.

model Usuario {
  id                  String      @id @default(uuid())
  nome                String
  email               String      @unique
  cpfCnpj             String?     @unique // só dígitos; nulo p/ contas antigas/seed
  rg                  String?     // obrigatório para pessoa física (CPF)
  celular             String?
  senhaHash           String?     // nulo p/ contas criadas só por login social
  papel               Papel       @default(ALUNO)
  escolaridade        String?     // nível: Ensino Fundamental | Médio | Superior
  escolaridadeSituacao String?    // Cursando | Completo
  genero              String?     // Masculino | Feminino | Outro | Prefiro não informar (opcional)
  // Endereço (opcional) — finalidade: cobrança em caso de inadimplência
  cep                 String?
  logradouro          String?
  numero              String?
  complemento         String?
  bairro              String?
  cidade              String?
  uf                  String?
  emailVerificado     Boolean     @default(false)
  // Bloqueio temporário por tentativas de senha erradas
  loginFalhas         Int         @default(0)
  bloqueadoAte        DateTime?
  // Escalada: nº de bloqueios temporários acumulados e bloqueio total (desbloqueio manual)
  loginStrikes        Int         @default(0)
  bloqueioTotal       Boolean     @default(false)
  avatarUrl           String?     // foto vinda do provedor social (opcional)
  // LGPD: registramos QUANDO consentiu e QUAL versão da política aceitou
  consentimentoLgpdEm DateTime?
  consentimentoVersao String?
  criadoEm            DateTime    @default(now())
  atualizadoEm        DateTime    @updatedAt
  matriculas          Matricula[]
}

// ---------- Catálogo de cursos ----------

model Curso {
  id                 String   @id @default(uuid())
  nome               String
  descricao          String?
  descricaoLonga     String? // texto completo exibido na página do curso
  cargaHoraria       Int // em horas
  escolaridadeMinima String?
  imagemUrl          String? // foto do card (placeholder por ora; trocar por foto real)
  precoAvista        Decimal  @db.Decimal(10, 2) // preço com desconto à vista
  precoCheio         Decimal  @db.Decimal(10, 2) // preço cheio (base do parcelamento)
  parcelas           Int      @default(1)
  valorParcela       Decimal  @db.Decimal(10, 2)
  // Taxa de matrícula POR CURSO. Se null, usa o padrão global (tabela Configuracao).
  // Defina 0 para um curso sem taxa. Veja "matricula_modo" no README.
  taxaMatricula      Decimal? @db.Decimal(10, 2)
  ativo              Boolean  @default(true)
  criadoEm           DateTime @default(now())
  turmas             Turma[]
  faqs               FaqCurso[]
}

// Dúvida frequente de um curso (editável pela secretaria).
model FaqCurso {
  id       String   @id @default(uuid())
  curso    Curso    @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  cursoId  String
  pergunta String
  resposta String
  ordem    Int      @default(0)
  criadoEm DateTime @default(now())

  @@index([cursoId])
}

// ---------- Turma (oferta concreta de um curso, com datas) ----------

model Turma {
  id             String      @id @default(uuid())
  curso          Curso       @relation(fields: [cursoId], references: [id])
  cursoId        String
  inicioPrevisto DateTime
  fimPrevisto    DateTime?
  horario        String // ex.: "18:00-22:00"
  diasSemana     String // ex.: "Terças e Quintas"
  vagas          Int         @default(30)
  minimoAlunos   Int         @default(15)
  status         StatusTurma @default(ABERTA)
  criadoEm       DateTime    @default(now())
  matriculas     Matricula[]
}

// ---------- Matrícula (aluno em uma turma) ----------

model Matricula {
  id                 String          @id @default(uuid())
  aluno              Usuario         @relation(fields: [alunoId], references: [id])
  alunoId            String
  turma              Turma           @relation(fields: [turmaId], references: [id])
  turmaId            String
  plano              PlanoPagamento
  forma              FormaPagamento
  // "Fotografamos" os valores no momento da matrícula (preço pode mudar depois)
  valorCurso         Decimal         @db.Decimal(10, 2)
  valorTaxaMatricula Decimal         @default(0) @db.Decimal(10, 2)
  alimentoEntregue   Boolean         @default(false) // 1kg de alimento não perecível
  statusPagamento    StatusPagamento @default(PENDENTE)
  // Avaliação lançada pela secretaria
  nota               Float?          // 0 a 10
  situacao           SituacaoAcademica?
  // Preenchidos quando a secretaria confirma um pagamento presencial
  confirmadaPor      String?
  confirmadaEm       DateTime?
  criadoEm           DateTime        @default(now())
  atualizadoEm       DateTime        @updatedAt
  pagamentos         Pagamento[]
  avaliacoes         Avaliacao[]

  @@unique([alunoId, turmaId]) // um aluno não matricula duas vezes na mesma turma
}

// ---------- Pagamento ----------
// Cartão/Pix: criado e confirmado via gateway (webhook). Dinheiro: confirmação manual.
// O número do cartão NUNCA passa por aqui — fica só no checkout do gateway.

model Pagamento {
  id           String          @id @default(uuid())
  matricula    Matricula       @relation(fields: [matriculaId], references: [id])
  matriculaId  String
  gateway      String? // ex.: "mercadopago" (null se presencial)
  gatewayRef   String? // id da transação no gateway, para conciliar com o webhook
  metodo       FormaPagamento
  valor        Decimal         @db.Decimal(10, 2)
  status       StatusPagamento @default(PENDENTE)
  criadoEm     DateTime        @default(now())
  atualizadoEm DateTime        @updatedAt
}

// ---------- Tokens (verificação de e-mail / recuperação de senha) ----------
// Guardamos o HASH do token, nunca o token em claro. Uso único e com expiração.

model TokenAuth {
  id        String    @id @default(uuid())
  usuarioId String
  tipo      String // "VERIFICACAO_EMAIL" | "RESET_SENHA"
  tokenHash String
  expiraEm  DateTime
  usadoEm   DateTime?
  criadoEm  DateTime  @default(now())
}

// ---------- Configurações (chave/valor) ----------
// Aqui mora a flexibilidade da taxa de matrícula:
//   matricula_modo         = "POR_CURSO" | "POR_ALUNO" | "NENHUMA"
//   matricula_valor_padrao = "100.00"
// Trocar para "NENHUMA" (ou zerar) remove a taxa sem mexer no código.

model Configuracao {
  chave String @id
  valor String
}

// ---------- Log de auditoria (ações da secretaria) ----------

model LogAuditoria {
  id       String   @id @default(uuid())
  atorId   String // id da secretaria que executou a ação
  acao     String // ex.: "CONFIRMOU_PAGAMENTO"
  alvoTipo String // ex.: "Matricula"
  alvoId   String?
  detalhe  Json?
  criadoEm DateTime @default(now())
}

// Avaliação individual de uma inscrição (prova, trabalho, etc.).
// A nota final da matrícula (Matricula.nota) é a MÉDIA PONDERADA destas.
model Avaliacao {
  id          String    @id @default(uuid())
  matricula   Matricula @relation(fields: [matriculaId], references: [id], onDelete: Cascade)
  matriculaId String
  nome        String // ex.: "Prova 1", "Trabalho final"
  nota        Float // 0 a 10
  peso        Float     @default(1) // peso na média ponderada
  criadoEm    DateTime  @default(now())

  @@index([matriculaId])
}
