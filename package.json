{
  "name": "escola-cruz-vermelha",
  "version": "0.1.0",
  "private": true,
  "description": "Escola de Capacitação da Cruz Vermelha Brasileira (RJ) — backend e área autenticada",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev --name init",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "node prisma/seed.js",
    "db:seed:limpar": "node prisma/limpar-exemplos.js",
    "db:limpar:alunos": "node prisma/limpar-alunos.js",
    "admin:desbloquear": "node prisma/desbloquear-admin.js",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5",
    "argon2": "^0.41",
    "connect-pg-simple": "^9",
    "dotenv": "^16",
    "ejs": "^3",
    "express": "^4",
    "express-rate-limit": "^7",
    "express-session": "^1",
    "helmet": "^7",
    "multer": "^1.4.5-lts.1",
    "pg": "^8",
    "resend": "^4",
    "zxcvbn": "^4",
    "zod": "^3"
  },
  "devDependencies": {
    "prisma": "^5"
  }
}
