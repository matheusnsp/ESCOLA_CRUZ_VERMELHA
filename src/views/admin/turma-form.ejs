<%- include('head', { titulo: 'Turma' }) %>
<%- include('header', { ativo: 'turmas' }) %>
<% var t = turma || {}; var novo = !t.id;
   function dtLocal(v){ if(!v) return ''; var d=new Date(v); if(isNaN(d)) return v; return new Date(d.getTime()-d.getTimezoneOffset()*60000).toISOString().slice(0,16); }
%>
<div class="adm-h1-row"><h1 class="adm-h1"><%= novo ? 'Nova turma' : 'Editar turma' %></h1><a href="/turmas" class="adm-link">← Voltar</a></div>
<% if (erro) { %><div class="adm-erro"><i class="fa-solid fa-circle-exclamation"></i> <%= erro %></div><% } %>
<form method="POST" action="<%= novo ? '/turmas' : '/turmas/' + t.id %>" class="adm-form adm-box">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <label class="full">Curso
    <select name="cursoId" required>
      <option value="">— selecione —</option>
      <% cursos.forEach(function(cur){ %>
        <option value="<%= cur.id %>" <%= (t.cursoId||'')===cur.id ? 'selected' : '' %>><%= cur.nome %></option>
      <% }) %>
    </select>
  </label>
  <label>Início previsto<input type="datetime-local" name="inicioPrevisto" value="<%= dtLocal(t.inicioPrevisto) %>" required></label>
  <label>Fim previsto (opcional)<input type="datetime-local" name="fimPrevisto" value="<%= dtLocal(t.fimPrevisto) %>"></label>
  <label>Horário<input type="text" name="horario" value="<%= t.horario || '18:00-22:00' %>" required></label>
  <label>Dias da semana<input type="text" name="diasSemana" value="<%= t.diasSemana || '' %>" placeholder="Terças e Quintas" required></label>
  <label>Vagas<input type="number" name="vagas" min="1" value="<%= t.vagas || 30 %>" required></label>
  <label>Mínimo de alunos<input type="number" name="minimoAlunos" min="0" value="<%= t.minimoAlunos != null ? t.minimoAlunos : 15 %>" required></label>
  <label>Status
    <select name="status">
      <% statusTurma.forEach(function(s){ %>
        <option value="<%= s %>" <%= (t.status||'ABERTA')===s ? 'selected' : '' %>><%= s %></option>
      <% }) %>
    </select>
  </label>
  <div class="full"><button type="submit" class="adm-btn"><%= novo ? 'Criar turma' : 'Salvar alterações' %></button></div>
</form>
<%- include('foot') %>
