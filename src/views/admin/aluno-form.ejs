<%- include('head', { titulo: 'Editar aluno' }) %>
<%- include('header', { ativo: 'alunos' }) %>
<div class="adm-h1-row"><h1 class="adm-h1">Editar aluno</h1><a href="/alunos" class="adm-link">← Voltar</a></div>
<% if (erro) { %><div class="adm-erro"><i class="fa-solid fa-circle-exclamation"></i> <%= erro %></div><% } %>

<form method="POST" action="/alunos/<%= aluno.id %>/editar" class="adm-box" style="padding:24px;">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

  <div class="adm-form" style="padding:0;display:grid;grid-template-columns:1fr;gap:14px;">
    <label class="full">Nome completo
      <input type="text" name="nome" value="<%= aluno.nome %>" required>
      <small style="color:#6b7689;font-weight:400;">Usado no certificado. Confira a grafia.</small>
    </label>
  </div>

  <fieldset style="border:1px solid #e7ebf1;border-radius:12px;padding:18px;margin-top:18px;">
    <legend style="font-size:13px;font-weight:700;padding:0 6px;">Contato</legend>
    <div class="adm-form" style="padding:0;display:grid;grid-template-columns:2fr 1fr;gap:16px;">
      <label>E-mail (login)
        <input type="email" name="email" value="<%= aluno.email %>" required maxlength="180">
      </label>
      <label>Celular
        <input type="text" name="celular" value="<%= aluno.celular || '' %>" inputmode="numeric" placeholder="(21) 99999-9999" maxlength="15" data-mask="celular">
      </label>
    </div>
  </fieldset>

  <fieldset style="border:1px solid #e7ebf1;border-radius:12px;padding:18px;margin-top:18px;">
    <legend style="font-size:13px;font-weight:700;padding:0 6px;">Documentos</legend>
    <div class="adm-form" style="padding:0;display:grid;grid-template-columns:1fr 1fr;gap:16px;">
      <% if (aluno.tipoDocumento === 'PASSAPORTE') { %>
        <label>Passaporte
          <input type="text" name="passaporte" value="<%= passaporteDigitado || aluno.passaporte || '' %>" maxlength="20" placeholder="Ex: AB1234567">
          <small style="color:#6b7689;font-weight:400;">Deixe em branco para manter o atual.</small>
        </label>
        <label>País de origem
          <input type="text" name="paisOrigem" value="<%= aluno.paisOrigem || '' %>" placeholder="Ex: Argentina">
        </label>
      <% } else { %>
        <label>CPF ou CNPJ
          <input type="text" name="cpfCnpj" value="<%= cpfCnpjDigitado %>" inputmode="numeric" placeholder="<%= cpfCnpjAtualMascarado ? 'Atual: ' + cpfCnpjAtualMascarado : 'Somente números' %>" maxlength="18" data-mask="cpfCnpj">
          <small style="color:#6b7689;font-weight:400;">Deixe em branco para manter o documento atual<%= cpfCnpjAtualMascarado ? '' : ' (nenhum cadastrado)' %>.</small>
        </label>
        <label>RG
          <input type="text" name="rg" value="<%= rgDigitado %>" maxlength="14" placeholder="<%= rgAtualMascarado ? 'Atual: ' + rgAtualMascarado : 'Número do RG' %>" data-mask="rg">
          <small style="color:#6b7689;font-weight:400;">Deixe em branco para manter o RG atual<%= rgAtualMascarado ? '' : ' (nenhum cadastrado)' %>.</small>
        </label>
      <% } %>
    </div>
  </fieldset>

  <fieldset style="border:1px solid #e7ebf1;border-radius:12px;padding:18px;margin-top:18px;">
    <legend style="font-size:13px;font-weight:700;padding:0 6px;">Perfil</legend>
    <div class="adm-form" style="padding:0;display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;">
      <label>Escolaridade
        <select name="escolaridade">
          <option value="">— não informada —</option>
          <% escolaridades.forEach(function (e) { %>
            <option value="<%= e %>" <%= aluno.escolaridade === e ? 'selected' : '' %>><%= e %></option>
          <% }) %>
        </select>
      </label>
      <label>Situação
        <select name="escolaridadeSituacao">
          <option value="">— não informada —</option>
          <% situacoes.forEach(function (s) { %>
            <option value="<%= s %>" <%= aluno.escolaridadeSituacao === s ? 'selected' : '' %>><%= s %></option>
          <% }) %>
        </select>
      </label>
      <label>Gênero
        <select name="genero">
          <option value="">— não informado —</option>
          <% generos.forEach(function (g) { %>
            <option value="<%= g %>" <%= aluno.genero === g ? 'selected' : '' %>><%= g %></option>
          <% }) %>
        </select>
      </label>
    </div>
  </fieldset>

  <fieldset style="border:1px solid #e7ebf1;border-radius:12px;padding:18px;margin-top:18px;">
    <legend style="font-size:13px;font-weight:700;padding:0 6px;">Endereço (para cobrança)</legend>
    <div class="adm-form" style="padding:0;display:grid;grid-template-columns:1fr 3fr 1fr 1.5fr;gap:16px;">
      <label>CEP
        <input type="text" name="cep" value="<%= aluno.cep || '' %>" inputmode="numeric" placeholder="00000000" maxlength="9">
      </label>
      <label>Rua / Logradouro
        <input type="text" name="logradouro" value="<%= aluno.logradouro || '' %>">
      </label>
      <label>Número
        <input type="text" name="numero" value="<%= aluno.numero || '' %>">
      </label>
      <label>Complemento
        <input type="text" name="complemento" value="<%= aluno.complemento || '' %>">
      </label>
    </div>
    <div class="adm-form" style="padding:0;margin-top:16px;display:grid;grid-template-columns:2fr 2fr 1fr;gap:16px;">
      <label>Bairro
        <input type="text" name="bairro" value="<%= aluno.bairro || '' %>">
      </label>
      <label>Cidade
        <input type="text" name="cidade" value="<%= aluno.cidade || '' %>">
      </label>
      <label>UF
        <select name="uf">
          <option value="">--</option>
          <% ufs.forEach(function (u) { %>
            <option value="<%= u %>" <%= aluno.uf === u ? 'selected' : '' %>><%= u %></option>
          <% }) %>
        </select>
      </label>
    </div>
  </fieldset>

  <p class="adm-mut" style="font-size:13px;margin:16px 0 18px;"><i class="fa-solid fa-triangle-exclamation"></i> E-mail e CPF/CNPJ são usados para login e identidade do aluno (inclusive no certificado). Alterações aqui ficam registradas na auditoria.</p>

  <button type="submit" class="adm-btn"><i class="fa-solid fa-floppy-disk"></i> Salvar alterações</button>
</form>
<%- include('foot') %>
<script src="/js/mascaras.js"></script>