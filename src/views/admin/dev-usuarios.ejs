<%- include('head', { titulo: 'Usuários Admin' }) %>
<%- include('header', { ativo: 'dev-usuarios' }) %>

<div class="adm-h1-row">
  <h1 class="adm-h1">Usuários Admin</h1>
  <a href="/dev/usuarios/novo" class="adm-btn"><i class="fa-solid fa-plus"></i> Novo admin</a>
</div>

<% if (ok) { %><div class="adm-ok"><i class="fa-solid fa-circle-check"></i> <%= ok %></div><% } %>
<% if (erro) { %><div class="adm-erro"><i class="fa-solid fa-circle-exclamation"></i> <%= erro %></div><% } %>

<div class="adm-box">
  <% if (!linhas.length) { %>
    <p class="adm-vazio">Nenhum usuário admin cadastrado.</p>
  <% } else { %>
    <table class="adm-table">
      <thead>
        <tr>
          <th>Nome</th>
          <th>E-mail</th>
          <th>Papel</th>
          <th>Permissões</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% linhas.forEach(function(u) { %>
          <tr>
            <td><strong><%= u.nome %></strong></td>
            <td><small class="adm-mut"><%= u.email %></small></td>
            <td><span class="badge ok"><%= u.papel %></span></td>
            <td>
              <div style="display:flex;flex-wrap:wrap;gap:4px;">
                <% u.permissoes.forEach(function(p) { %>
                  <code style="font-size:11px;background:#f0f2f5;border-radius:6px;padding:2px 6px;"><%= p %></code>
                <% }) %>
              </div>
            </td>
            <td class="adm-acoes">
              <% if (u.id === meuId) { %>
                <span class="adm-mut" style="font-size:12px;">é você</span>
              <% } else { %>
                <form method="POST" action="/dev/usuarios/<%= u.id %>/papel" style="display:flex;gap:6px;align-items:center;">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <select name="papel" style="font-size:13px;">
                    <% papeis.forEach(function(p) { %>
                      <option value="<%= p %>" <%= p === u.papel ? 'selected' : '' %>><%= p %></option>
                    <% }) %>
                  </select>
                  <button type="submit" class="adm-mini" title="Salvar"><i class="fa-solid fa-check"></i></button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<%- include('foot') %>