<%- include('partials/head', { titulo: 'Painel da Secretaria' }) %>

<main class="auth-wrap">
  <div class="auth-card auth-card-center">
    <div class="auth-icone-info"><i class="fa-solid fa-user-shield"></i></div>
    <h1>Painel da Secretaria</h1>
    <p class="auth-sub">Bem-vindo(a), <%= nome %>. Em breve: alunos, inscrições, confirmação de pagamentos e log de auditoria.</p>

    <form method="POST" action="/logout">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="auth-btn">Sair</button>
    </form>
  </div>
</main>

<%- include('partials/foot') %>
