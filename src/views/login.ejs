<%- include('partials/head', { titulo: 'Entrar' }) %>
<main class="auth-wrap">
  <div class="auth-card">
    <div class="auth-brand">
      <i class="fa-solid fa-plus"></i>
      <div class="auth-brand-text">
        <strong>CRUZ VERMELHA</strong>
        <span>Escola de Capacitação</span>
      </div>
    </div>
    <h1>Entrar</h1>
    <p class="auth-sub">Acesse sua conta para ver seus cursos.</p>

    <% if (typeof sucesso !== 'undefined' && sucesso) { %>
        <div class="auth-erros" style="background:#f0fdf4;border-color:#86efac;">
          <p style="color:#16a34a;"><i class="fa-solid fa-circle-check"></i> <%= sucesso %></p>
        </div>
        <% } %>
        <% if (erro) { %>
        <div class="auth-erros" role="alert">
          <p><i class="fa-solid fa-circle-exclamation"></i> <%= erro %></p>
        </div>
        <% } %>

    <form method="POST" action="/login" novalidate>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label class="auth-field">
        <span>E-mail</span>
        <input type="email" name="email" value="<%= email || '' %>" required autocomplete="email">
      </label>
      <label class="auth-field">
        <span>Senha</span>
        <input type="password" name="senha" required autocomplete="current-password">
      </label>
      
      <button type="submit" class="auth-btn">Entrar</button>
    </form>

    <div style="text-align:right; margin-top:-8px; margin-bottom:16px;">
        <a href="/esqueci-senha" style="font-size:13px; color:var(--gray-500); text-decoration:none;">
          Esqueci minha senha
        </a>
      </div>
    <p class="auth-alt" style="margin-top:0;font-size:13px;">Não confirmou o e-mail? <a href="/reenviar-confirmacao">Reenviar confirmação</a></p>
    <p class="auth-alt">Não tem conta? <a href="/cadastro">Criar conta</a></p>
  </div>
</main>
<%- include('partials/foot') %>