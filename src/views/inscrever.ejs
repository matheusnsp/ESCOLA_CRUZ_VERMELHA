<%- include('partials/site-head', { titulo: 'Inscrição' }) %>
<%- include('partials/site-header') %>

<main class="interna-wrap">
  <a href="/cursos/<%= curso.id %>" class="cat-back" style="margin:0;"><i class="fa-solid fa-arrow-left"></i> Voltar ao curso</a>

  <div class="painel-card">
    <h1><%= curso.nome %></h1>
    <p class="painel-sub">
      <%= turma.diasSemana %> · <%= turma.horario %> ·
      início em <%= new Date(turma.inicioPrevisto).toLocaleDateString('pt-BR') %>
    </p>

    <% if (erro) { %>
      <div class="aviso-erro"><i class="fa-solid fa-circle-exclamation"></i> <%= erro %></div>
    <% } %>

    <div class="resumo-box">
      <div><span>Curso (à vista)</span><strong><%= formatBRL(aVista.valorCurso) %></strong></div>
      <div><span>Curso (parcelado)</span><strong><%= formatBRL(parcelado.valorCurso) %></strong></div>
      <div><span>Taxa de matrícula</span><strong><%= formatBRL(aVista.valorTaxaMatricula) %></strong></div>
      <small>+ 1 kg de alimento não perecível, entregue na secretaria.</small>
    </div>

    <form method="POST" action="/inscrever/<%= turma.id %>" novalidate>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <label class="campo">
        <span>Plano</span>
        <select name="plano" id="selectPlano">
          <option value="A_VISTA">À vista (<%= formatBRL(aVista.total) %>)</option>
          <option value="PARCELADO">Parcelado (<%= turma.curso.parcelas %>x de <%= formatBRL(parcelado.valorParcela) %> = <%= formatBRL(parcelado.total) %>)</option>
        </select>
      </label>

      <label class="campo">
        <span>Forma de pagamento</span>
        <select name="forma" id="selectForma">
          <option value="PIX">PIX</option>
          <option value="CREDITO">Cartão de Crédito</option>
          <option value="DINHEIRO">Dinheiro / Espécie (Pagar na secretaria)</option>
        </select>
      </label>

      <div id="dadosDoCartao" style="display: none; border: 1px dashed #ccc; padding: 14px; margin-bottom: 14px; border-radius: 4px; background: #fafafa;">
        <h3 style="margin-top:0; font-size:15px; color:#333;">Dados do Cartão de Crédito</h3>

        <label class="campo">
          <span style="font-size: 13px;">Número do Cartão</span>
          <input type="text" name="numero" placeholder="0000 0000 0000 0000" style="width: 100%; padding: 8px; border-radius: 4px; border: 1px solid #ccc;">
        </label>

        <label class="campo">
          <span style="font-size: 13px;">Nome do Titular (como no cartão)</span>
          <input type="text" name="titular" placeholder="JOAO S SILVA" style="width: 100%; padding: 8px; border-radius: 4px; border: 1px solid #ccc;">
        </label>

        <div style="display: flex; gap: 10px;">
          <label class="campo" style="flex: 1;">
            <span style="font-size: 13px;">Validade (MM/AA)</span>
            <input type="text" name="validade" id="inputValidade" placeholder="12/28" maxlength="5" inputmode="numeric" style="width: 100%; padding: 8px; border-radius: 4px; border: 1px solid #ccc;">
          </label>

          <label class="campo" style="flex: 1;">
            <span style="font-size: 13px;">CVV</span>
            <input type="text" name="cvv" placeholder="123" maxlength="4" style="width: 100%; padding: 8px; border-radius: 4px; border: 1px solid #ccc;">
          </label>
        </div>
      </div>

      <button type="submit" class="btn-acao">Confirmar inscrição</button>
    </form>
    <p class="painel-sub" style="margin:14px 0 0;font-size:12px;">Sua matrícula ficará como "pendente" até a confirmation do pagamento.</p>
  </div>
</main>

<script>
  const selectPlano = document.getElementById('selectPlano');
  const selectForma = document.getElementById('selectForma');

  const OPCOES = {
    A_VISTA: [
      { value: 'PIX', label: 'PIX' },
      { value: 'CREDITO', label: 'Cartão de Crédito' },
      { value: 'DINHEIRO', label: 'Dinheiro / Espécie (Pagar na secretaria)' }
    ],
    PARCELADO: [
      { value: 'CREDITO', label: 'Cartão de Crédito' },
      { value: 'DINHEIRO', label: 'Dinheiro / Espécie (Pagar na secretaria)' }
    ]
  };

  function atualizarOpcoesForma() {
    const formaAtual = selectForma.value;
    const opcoes = OPCOES[selectPlano.value] || OPCOES.A_VISTA;

    selectForma.innerHTML = '';
    opcoes.forEach(op => {
      const opt = document.createElement('option');
      opt.value = op.value;
      opt.textContent = op.label;
      selectForma.appendChild(opt);
    });

    const aindaExiste = opcoes.some(op => op.value === formaAtual);
    selectForma.value = aindaExiste ? formaAtual : opcoes[0].value;

    selectForma.dispatchEvent(new Event('change'));
  }

  document.getElementById('selectForma').addEventListener('change', function() {
    const blocoCartao = document.getElementById('dadosDoCartao');
    const inputsCartao = blocoCartao.querySelectorAll('input');

    if (this.value === 'CREDITO') {
      blocoCartao.style.display = 'block';
      inputsCartao.forEach(input => input.removeAttribute('disabled'));
    } else {
      blocoCartao.style.display = 'none';
      inputsCartao.forEach(input => input.setAttribute('disabled', 'true'));
    }
  });

  document.getElementById('inputValidade').addEventListener('input', function(e) {
    let valor = e.target.value.replace(/\D/g, '');

    if (valor.length > 4) valor = valor.slice(0, 4);

    if (valor.length >= 3) {
      valor = valor.slice(0, 2) + '/' + valor.slice(2);
    }

    e.target.value = valor;
  });

  selectPlano.addEventListener('change', atualizarOpcoesForma);

  atualizarOpcoesForma();
</script>

<%- include('partials/site-footer') %>