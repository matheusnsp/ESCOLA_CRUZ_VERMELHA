</style>

<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script>
var etapaLabels = [
  'Etapa 1 de 3 — Contrato',
  'Etapa 2 de 3 — Taxa de inscrição',
  'Etapa 3 de 3 — Pagamento do curso',
  ''
];

function irEtapa(n) {
  document.querySelectorAll('.inscricao-etapa').forEach(function(el, i) {
    el.style.display = (i + 1 === n) ? 'block' : 'none';
  });
  document.querySelectorAll('.prog-step').forEach(function(el, i) {
    el.classList.toggle('active', i < n);
  });

  var label = document.getElementById('etapaLabel');
  var texto = etapaLabels[n - 1];
  if (texto) {
    label.textContent = texto;
    label.style.display = 'block';
  } else {
    label.style.display = 'none';
  }

  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// ---- Geração do payload PIX (BR Code / EMV) ----
function crc16(s) {
  let c = 0xFFFF;
  for (let i = 0; i < s.length; i++) {
    c ^= s.charCodeAt(i) << 8;
    for (let j = 0; j < 8; j++) c = (c & 0x8000) ? ((c << 1) ^ 0x1021) : (c << 1);
  }
  return (c & 0xFFFF).toString(16).toUpperCase().padStart(4, '0');
}
function f(id, v) {
  const l = v.length.toString().padStart(2, '0');
  return id + l + v;
}

var pixPayload = '';

function gerarPixPayload() {
  const chave = '67733551000135';
  const nome = 'Recebedor';
  const cidade = 'BRASIL';
  const valor = '100.00';

  const mi = f('00', 'BR.GOV.BCB.PIX') + f('01', chave);
  const gui = f('26', mi);
  let p = f('00', '01') + gui + f('52', '0000') + f('53', '986') + f('54', valor)
        + f('58', 'BR') + f('59', nome) + f('60', cidade) + f('62', f('05', '***')) + '6304';
  p += crc16(p);
  return p;
}

document.addEventListener('DOMContentLoaded', function () {

  // Gera o QR Code PIX (valor fixo R$ 100,00) e exibe o código copia e cola
  pixPayload = gerarPixPayload();
  document.getElementById('payload').textContent = pixPayload;
  new QRCode(document.getElementById('qr'), {
    text: pixPayload,
    width: 160,
    height: 160,
    correctLevel: QRCode.CorrectLevel.M
  });

  // Etapa 1 — habilitar botão ao aceitar contrato
  var checkbox = document.getElementById('aceiteContrato');
  var btnAceite = document.getElementById('btnAceite');
  checkbox.addEventListener('change', function () {
    btnAceite.disabled = !this.checked;
  });
  btnAceite.addEventListener('click', function () {
    irEtapa(2);
  });

  // Etapa 2 — expandir/recolher bloco da chave PIX
  var btnToggle = document.getElementById('btnToggleChavePix');
  var blocoChavePix = document.getElementById('blocoChavePix');
  var iconeChavePix = document.getElementById('iconeChavePix');
  btnToggle.addEventListener('click', function () {
    var aberto = blocoChavePix.style.display === 'block';
    blocoChavePix.style.display = aberto ? 'none' : 'block';
    iconeChavePix.style.transform = aberto ? 'rotate(0deg)' : 'rotate(180deg)';
  });

  // Etapa 2 — copiar código PIX (copia e cola)
  document.getElementById('btnCopiarPix').addEventListener('click', function (e) {
    var btn = e.currentTarget;
    navigator.clipboard.writeText(pixPayload).then(function () {
      var original = btn.innerHTML;
      btn.innerHTML = '<i class="fa-solid fa-check"></i> Copiado!';
      setTimeout(function () { btn.innerHTML = original; }, 2000);
    });
  });

  // Etapa 2 — avançar após enviar comprovante
  document.getElementById('btnEnviouComprovante').addEventListener('click', function () {
    irEtapa(3);
  });

  // Etapa 3 — apenas exibe as formas de pagamento aceitas, sem seleção do usuário

});
</script>